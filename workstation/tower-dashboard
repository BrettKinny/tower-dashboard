#!/bin/bash
# tower-dashboard — open the Unraid monitoring dashboard in a new terminal.
#
# The dashboard itself — a tmux session ('dash') running btop / nvtop / ctop /
# fan-status — lives server-side on the Unraid box (see tower/bin/tower-dash).
# This script just spawns a terminal that SSHes in and attaches to it. The
# session persists on the box between launches, so re-opening is instant.
#
# Environment:
#   TOWER_HOST  — SSH target                  (default: root@tower.local)
#   TERMINAL    — terminal emulator to spawn   (default: autodetected)
set -e

HOST="${TOWER_HOST:-root@tower.local}"

# TERM is pinned to a type the Unraid box is guaranteed to have terminfo for.
# Its RAM-FS carries the base ncurses set plus a restored tmux-256color, but
# not xterm-ghostty / xterm-kitty — passing the local TERM straight through
# would leave tmux unable to initialise the outer terminal.
REMOTE_CMD=(ssh -t "$HOST" 'TERM=xterm-256color exec tower-dash')

# Spawn the SSH command in a fresh terminal window — fresh, so it is NOT inside
# a local tmux (the only multiplexer in play is the one on the box). Try
# $TERMINAL first, then known emulators, each with its own "run this command"
# invocation. First one found wins; exec hands our process over to it.
for term in "${TERMINAL:-}" xdg-terminal-exec ghostty kitty alacritty foot wezterm gnome-terminal konsole xterm; do
  [ -z "$term" ] && continue
  command -v "$term" >/dev/null 2>&1 || continue
  case "$term" in
    xdg-terminal-exec) exec "$term" -- "${REMOTE_CMD[@]}" ;;
    wezterm)           exec "$term" start -- "${REMOTE_CMD[@]}" ;;
    gnome-terminal)    exec "$term" -- "${REMOTE_CMD[@]}" ;;
    kitty|foot)        exec "$term" "${REMOTE_CMD[@]}" ;;
    *)                 exec "$term" -e "${REMOTE_CMD[@]}" ;;
  esac
done

echo "tower-dashboard: no terminal emulator found. Set \$TERMINAL or install" \
     "one of: ghostty, kitty, alacritty, foot, wezterm, gnome-terminal," \
     "konsole, xterm." >&2
exit 1
